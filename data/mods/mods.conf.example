# mods.conf — single source of truth for all mods
#
# Format: <workshop_id>  <enabled>  <config_options>
#
#   workshop_id     — numeric Steam Workshop ID (the number in the URL)
#   enabled         — true | false
#   config_options  — optional, comma-separated key=value pairs
#
# Run `bash scripts/manage-mods.sh sync` after editing to regenerate the
# Lua files and download mods. Or use the CLI:
#
#   bash scripts/manage-mods.sh add 378160973 "SHOWFIREICONS=true"
#   bash scripts/manage-mods.sh remove 351325790
#   bash scripts/manage-mods.sh list
#   bash scripts/manage-mods.sh sync
#
# ── Examples (uncomment to enable) ─────────────────────
# 378160973  true  SHOWFIREICONS=true,SHAREMINIMAPPROGRESS=true
# 375859599  true
# 376333686  true
# 351325790  true
